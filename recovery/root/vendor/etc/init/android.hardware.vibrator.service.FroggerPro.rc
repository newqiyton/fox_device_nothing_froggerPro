on boot
    wait /dev/aac_richtap
    chown system system /dev/aac_richtap
    chmod 0600 /dev/aac_richtap
    start vendor.vibrator

service vendor.vibrator /vendor/bin/hw/android.hardware.vibrator.service.FroggerPro
    class late_start
    user system
    group system input
    setenv RICHTAP_DEVICE_PATH /dev/aac_richtap
    setenv ENV_RICHTAP_CONFIG_PATH /vendor/odm/etc/aac_richtap.config
    seclabel u:r:recovery:s0
    interface aidl android.hardware.vibrator.IVibrator/default
    disabled

